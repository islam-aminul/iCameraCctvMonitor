<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.tcs.ion.iCamera.cctv.controller.SystemHardwareController"
      styleClass="page-root" spacing="0">
    <padding><Insets top="8" left="8" right="8" bottom="8"/></padding>

    <TabPane fx:id="tabPaneHardware" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

        <!-- ====== Tab 1: CPU ====== -->
        <Tab text="CPU">
            <ScrollPane fitToWidth="true" styleClass="page-scroll">
                <VBox spacing="12" style="-fx-padding:16;">
                    <Label fx:id="lblCpuName"    styleClass="detail-value"/>
                    <Label fx:id="lblCpuCores"   styleClass="detail-value"/>
                    <Label fx:id="lblCpuThreads" styleClass="detail-value"/>
                    <Label fx:id="lblCpuFreq"    styleClass="detail-value"/>
                    <Separator/>
                    <Label fx:id="lblCpuUsage"       styleClass="detail-value"/>
                    <ProgressBar fx:id="pbCpuSystem" progress="0" maxWidth="Infinity"/>
                    <Label fx:id="lblProxyCpuUsage"  styleClass="detail-value text-blue"/>
                    <ProgressBar fx:id="pbCpuProxy"  progress="0" maxWidth="Infinity"/>
                </VBox>
            </ScrollPane>
        </Tab>

        <!-- ====== Tab 2: Memory ====== -->
        <Tab text="Memory">
            <ScrollPane fitToWidth="true" styleClass="page-scroll">
                <VBox spacing="12" style="-fx-padding:16;">
                    <Label fx:id="lblRamTotal"       styleClass="detail-value"/>
                    <Label fx:id="lblRamAvail"       styleClass="detail-value"/>
                    <Label fx:id="lblRamType"        styleClass="detail-value"/>
                    <Separator/>
                    <Label fx:id="lblRamUsage"       styleClass="detail-value"/>
                    <ProgressBar fx:id="pbRam"       progress="0" maxWidth="Infinity"/>
                    <Label fx:id="lblProxyRamUsage"  styleClass="detail-value text-blue"/>
                </VBox>
            </ScrollPane>
        </Tab>

        <!-- ====== Tab 3: Storage Drives ====== -->
        <Tab text="Storage Drives">
            <ScrollPane fitToWidth="true" styleClass="page-scroll">
                <VBox fx:id="vboxDrives" spacing="8" style="-fx-padding:16;"/>
            </ScrollPane>
        </Tab>

        <!-- ====== Tab 4: Top Processes ====== -->
        <Tab text="Top Processes">
            <VBox spacing="0">
                <TabPane fx:id="tabPaneProcs" tabClosingPolicy="UNAVAILABLE">

                    <Tab text="All">
                        <TableView fx:id="tblTopAll" prefHeight="320" styleClass="data-table"
                                   VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="allColPid"   text="PID"       prefWidth="65"/>
                                <TableColumn fx:id="allColName"  text="Process"   prefWidth="210"/>
                                <TableColumn fx:id="allColUser"  text="User"      prefWidth="120"/>
                                <TableColumn fx:id="allColCpu"   text="CPU %"     prefWidth="85"/>
                                <TableColumn fx:id="allColMem"   text="Memory"    prefWidth="100"/>
                                <TableColumn fx:id="allColRead"  text="Disk Read" prefWidth="100"/>
                            </columns>
                            <placeholder><Label text="No data yet" styleClass="tile-sublabel"/></placeholder>
                        </TableView>
                    </Tab>

                    <Tab text="CPU">
                        <TableView fx:id="tblTopCpu" prefHeight="320" styleClass="data-table">
                            <columns>
                                <TableColumn fx:id="cpuColPid"  text="PID"    prefWidth="70"/>
                                <TableColumn fx:id="cpuColName" text="Process" prefWidth="220"/>
                                <TableColumn fx:id="cpuColUser" text="User"    prefWidth="130"/>
                                <TableColumn fx:id="cpuColCpu"  text="CPU %"   prefWidth="90"/>
                                <TableColumn fx:id="cpuColMem"  text="Memory"  prefWidth="100"/>
                            </columns>
                            <placeholder><Label text="No data yet" styleClass="tile-sublabel"/></placeholder>
                        </TableView>
                    </Tab>

                    <Tab text="Memory">
                        <TableView fx:id="tblTopMem" prefHeight="320" styleClass="data-table">
                            <columns>
                                <TableColumn fx:id="memColPid"  text="PID"    prefWidth="70"/>
                                <TableColumn fx:id="memColName" text="Process" prefWidth="220"/>
                                <TableColumn fx:id="memColUser" text="User"    prefWidth="130"/>
                                <TableColumn fx:id="memColMem"  text="Memory"  prefWidth="100"/>
                                <TableColumn fx:id="memColCpu"  text="CPU %"   prefWidth="90"/>
                            </columns>
                            <placeholder><Label text="No data yet" styleClass="tile-sublabel"/></placeholder>
                        </TableView>
                    </Tab>

                    <Tab text="Disk I/O">
                        <TableView fx:id="tblTopDisk" prefHeight="320" styleClass="data-table">
                            <columns>
                                <TableColumn fx:id="diskColPid"   text="PID"       prefWidth="70"/>
                                <TableColumn fx:id="diskColName"  text="Process"   prefWidth="200"/>
                                <TableColumn fx:id="diskColUser"  text="User"      prefWidth="120"/>
                                <TableColumn fx:id="diskColRead"  text="Disk Read"  prefWidth="110"/>
                                <TableColumn fx:id="diskColWrite" text="Disk Write" prefWidth="110"/>
                                <TableColumn fx:id="diskColMem"   text="Memory"    prefWidth="100"/>
                            </columns>
                            <placeholder><Label text="No data yet" styleClass="tile-sublabel"/></placeholder>
                        </TableView>
                    </Tab>
                </TabPane>
            </VBox>
        </Tab>

    </TabPane>
</VBox>
