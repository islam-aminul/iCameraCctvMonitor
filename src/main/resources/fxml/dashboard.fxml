<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tcs.ion.iCamera.cctv.controller.DashboardController"
            fitToWidth="true" styleClass="page-scroll">

    <VBox styleClass="page-root" spacing="20">
        <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>

        <!-- ===== Section 1: Application Health ===== -->
        <Label text="APPLICATION HEALTH" styleClass="tile-section-header"/>

        <HBox spacing="16" fillHeight="true">
            <!-- Proxy tile (tri-state: UP/DEGRADED/DOWN) -->
            <VBox fx:id="paneProxyTile" styleClass="tile" HBox.hgrow="ALWAYS" spacing="6">
                <padding><Insets topRightBottomLeft="12"/></padding>
                <Label text="PROXY STATUS" styleClass="tile-header"/>
                <Label fx:id="lblProxyStatus" styleClass="tile-value-large text-green" text="--"/>
                <Label fx:id="lblProxyId" styleClass="tile-sublabel"/>
                <Label fx:id="lblProxyName" styleClass="tile-sublabel"/>
                <!-- Sub-items: service & JMX status -->
                <HBox spacing="8" styleClass="hierarchy-indent">
                    <Label text="Service:" styleClass="detail-label"/>
                    <Label fx:id="lblServiceStatus" styleClass="detail-value" text="--"/>
                </HBox>
                <HBox spacing="8" styleClass="hierarchy-indent">
                    <Label text="JMX:" styleClass="detail-label"/>
                    <Label fx:id="lblJmxStatus" styleClass="detail-value" text="--"/>
                </HBox>
            </VBox>

            <!-- HSQLDB tile (tri-state: UP/DEGRADED/DOWN) -->
            <VBox fx:id="paneHsqldbTile" styleClass="tile" HBox.hgrow="ALWAYS" spacing="6">
                <padding><Insets topRightBottomLeft="12"/></padding>
                <Label text="HSQLDB DATABASE" styleClass="tile-header"/>
                <Label fx:id="lblHsqldbStatus" styleClass="tile-value-large text-green" text="--"/>
                <!-- Sub-items: service, JMX report, direct connectivity -->
                <HBox spacing="8" styleClass="hierarchy-indent">
                    <Label text="Service:" styleClass="detail-label"/>
                    <Label fx:id="lblHsqldbServiceStatus" styleClass="detail-value" text="--"/>
                </HBox>
                <HBox spacing="8" styleClass="hierarchy-indent">
                    <Label text="Direct:" styleClass="detail-label"/>
                    <Label fx:id="lblHsqldbDirect" styleClass="detail-value" text="--"/>
                </HBox>
            </VBox>

            <!-- CCTV tile -->
            <VBox styleClass="tile" HBox.hgrow="ALWAYS" spacing="6">
                <padding><Insets topRightBottomLeft="12"/></padding>
                <Label text="CCTV CAMERAS" styleClass="tile-header"/>
                <Label fx:id="lblCctvActive" styleClass="tile-value-large text-green"/>
                <Label fx:id="lblCctvTotal" styleClass="tile-sublabel"/>
                <ProgressBar fx:id="pbCctvActive" progress="0" maxWidth="Infinity"/>
                <Label fx:id="lblCctvWarning" styleClass="text-yellow" text="" visible="false" managed="false"/>
            </VBox>

            <!-- MAC Address tile (moved from Network section) -->
            <VBox styleClass="tile" HBox.hgrow="ALWAYS" spacing="6">
                <padding><Insets topRightBottomLeft="12"/></padding>
                <Label text="MAC ADDRESS" styleClass="tile-header"/>
                <Label fx:id="lblCurrentMac" styleClass="tile-sublabel"/>
                <Label fx:id="lblLastMac" styleClass="tile-sublabel"/>
                <Label fx:id="lblMacWarning" styleClass="text-yellow" text="MAC Mismatch Detected!" visible="false"/>
            </VBox>
        </HBox>

        <!-- ===== Section 2: System Resources ===== -->
        <Label text="SYSTEM RESOURCES" styleClass="tile-section-header"/>

        <HBox spacing="16" fillHeight="true">
            <!-- CPU tile -->
            <VBox fx:id="paneCpuTile" styleClass="tile" HBox.hgrow="ALWAYS" spacing="6">
                <padding><Insets topRightBottomLeft="12"/></padding>
                <Label text="CPU USAGE" styleClass="tile-header"/>
                <Label fx:id="lblCpuPercent" styleClass="tile-value-large" text="--"/>
                <ProgressBar fx:id="pbCpu" progress="0" maxWidth="Infinity"/>
            </VBox>

            <!-- Memory tile -->
            <VBox fx:id="paneMemTile" styleClass="tile" HBox.hgrow="ALWAYS" spacing="6">
                <padding><Insets topRightBottomLeft="12"/></padding>
                <Label text="MEMORY USAGE" styleClass="tile-header"/>
                <Label fx:id="lblMemPercent" styleClass="tile-value-large" text="--"/>
                <ProgressBar fx:id="pbMem" progress="0" maxWidth="Infinity"/>
            </VBox>

            <!-- Disk tile (similar to CPU/Memory) -->
            <VBox fx:id="paneDiskTile" styleClass="tile" HBox.hgrow="ALWAYS" spacing="6">
                <padding><Insets topRightBottomLeft="12"/></padding>
                <Label text="DISK USAGE" styleClass="tile-header"/>
                <Label fx:id="lblDiskPercent" styleClass="tile-value-large" text="--"/>
                <Label fx:id="lblDiskSummary" styleClass="tile-sublabel"/>
                <ProgressBar fx:id="pbDisk" progress="0" maxWidth="Infinity"/>
            </VBox>
        </HBox>

        <!-- ===== Section 3: Network & Connectivity ===== -->
        <Label text="NETWORK &amp; CONNECTIVITY" styleClass="tile-section-header"/>

        <HBox spacing="16" fillHeight="true">
            <!-- Network tile -->
            <VBox fx:id="paneNetworkTile" styleClass="tile" HBox.hgrow="ALWAYS" spacing="6">
                <padding><Insets topRightBottomLeft="12"/></padding>
                <Label text="NETWORK UPLOAD" styleClass="tile-header"/>
                <Label fx:id="lblNetworkSpeed" styleClass="tile-value-large text-blue" text="--"/>
                <Label text="to AWS" styleClass="tile-sublabel"/>
            </VBox>

            <!-- Spacers to balance layout -->
            <VBox HBox.hgrow="ALWAYS"/>
            <VBox HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>
</ScrollPane>
