<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.*?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.tcs.ion.iCamera.cctv.controller.NetworkMonitorController"
      styleClass="page-root" spacing="16">
    <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>

    <Label text="Network Monitor" styleClass="page-title"/>
    <Separator/>

    <!-- Current speed metrics -->
    <HBox spacing="24" styleClass="summary-bar">
        <VBox spacing="4">
            <Label text="Current Upload Speed" styleClass="tile-header"/>
            <Label fx:id="lblCurrentSpeed" styleClass="tile-value-large text-blue" text="0.00 MB/s"/>
        </VBox>
        <VBox spacing="4">
            <Label text="Peak" styleClass="tile-header"/>
            <Label fx:id="lblPeakSpeed" styleClass="detail-value text-green"/>
        </VBox>
        <VBox spacing="4">
            <Label text="Average" styleClass="tile-header"/>
            <Label fx:id="lblAvgSpeed"  styleClass="detail-value text-white"/>
        </VBox>
    </HBox>

    <!-- Line chart -->
    <LineChart fx:id="chartUploadSpeed" VBox.vgrow="ALWAYS" styleClass="network-chart"
               animated="false" legendVisible="true">
        <xAxis><CategoryAxis fx:id="xAxis" label="Time"/></xAxis>
        <yAxis><NumberAxis fx:id="yAxis"   label="MB/s" lowerBound="0" autoRanging="true"/></yAxis>
    </LineChart>

    <!-- History table -->
    <TableView fx:id="tableHistory" prefHeight="200" styleClass="data-table">
        <columns>
            <TableColumn fx:id="colTime"  text="Timestamp"  prefWidth="160"/>
            <TableColumn fx:id="colSpeed" text="Upload Speed" prefWidth="160"/>
        </columns>
    </TableView>
</VBox>
