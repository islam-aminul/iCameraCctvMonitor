<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tcs.ion.iCamera.cctv.controller.MainController"
            styleClass="root-pane">

    <!-- ===== Top area: header + tab navigation ===== -->
    <top>
        <VBox>
            <!-- Header bar: TC info, proxy ID, clock, last updated — entire background colored by RAG -->
            <HBox fx:id="headerBar" styleClass="header-bar" alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="lblTitle" styleClass="app-title" text="iCamera CCTV Monitor"/>
                <Separator orientation="VERTICAL" styleClass="header-sep"/>
                <Label fx:id="lblTcCode" styleClass="header-info-label" text="TC: --"/>
                <Separator orientation="VERTICAL" styleClass="header-sep"/>
                <Label fx:id="lblProxyId" styleClass="header-info-label" text="Proxy: --"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblClock" styleClass="header-clock" text="--"/>
                <Separator orientation="VERTICAL" styleClass="header-sep"/>
                <Label fx:id="lblLastRefresh" styleClass="header-info-label" text="Updated: --"/>
            </HBox>

            <!-- Level 1: Primary tab navigation -->
            <HBox fx:id="tabBar" styleClass="tab-bar" alignment="CENTER_LEFT" spacing="0">
                <padding><Insets top="0" left="8" right="8" bottom="0"/></padding>
                <Button fx:id="tabDashboard"     text="Dashboard"     onAction="#showDashboard"     styleClass="main-tab, main-tab-active"/>
                <Button fx:id="tabApplication"   text="Application"   onAction="#showApplication"   styleClass="main-tab"/>
                <Button fx:id="tabSystem"        text="System"        onAction="#showSystem"        styleClass="main-tab"/>
                <Button fx:id="tabAlerts"        text="Alerts"        onAction="#showAlerts"        styleClass="main-tab"/>
                <StackPane>
                    <Button fx:id="tabAlertsHidden" visible="false" managed="false"/>
                    <Label fx:id="lblAlertBadge" styleClass="alert-badge" visible="false"
                           StackPane.alignment="CENTER_RIGHT" translateX="-4"/>
                </StackPane>
                <Button fx:id="tabDiscovery"     text="Discovery"     onAction="#showDiscovery"     styleClass="main-tab"/>
                <Button fx:id="tabSettings"      text="Settings"      onAction="#showSettings"      styleClass="main-tab"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="v1.0.0 | TCS iON" styleClass="tab-bar-version"/>
            </HBox>

            <!-- Level 2: Sub-tab navigation (shown when Application or System is selected) -->
            <HBox fx:id="subTabBar" styleClass="sub-tab-bar" alignment="CENTER_LEFT" spacing="0"
                  visible="false" managed="false">
                <padding><Insets top="0" left="8" right="8" bottom="0"/></padding>
                <!-- Sub-tabs are populated dynamically by MainController -->
            </HBox>
        </VBox>
    </top>

    <!-- ===== Main content area ===== -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area"/>
    </center>

    <!-- ===== Right: Active Issues Panel (permanently visible) ===== -->
    <right>
        <VBox fx:id="issuesPanel" styleClass="issues-panel" prefWidth="300" minWidth="280" maxWidth="320">
            <!-- Panel header -->
            <HBox styleClass="issues-panel-header" alignment="CENTER_LEFT" spacing="8">
                <padding><Insets top="10" left="12" right="12" bottom="10"/></padding>
                <Label text="Active Issues" styleClass="issues-panel-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblIssueCount" styleClass="issue-count-badge" text="0"/>
            </HBox>
            <Separator styleClass="issues-panel-sep"/>

            <!-- Scrollable issues list -->
            <ScrollPane fx:id="issuesScrollPane" fitToWidth="true" styleClass="issues-scroll"
                        VBox.vgrow="ALWAYS">
                <VBox fx:id="issuesList" styleClass="issues-list" spacing="8">
                    <padding><Insets top="8" left="8" right="8" bottom="8"/></padding>
                </VBox>
            </ScrollPane>

            <!-- Export button at bottom -->
            <VBox styleClass="export-section" spacing="8">
                <padding><Insets top="10" left="12" right="12" bottom="12"/></padding>
                <Separator/>
                <Button fx:id="btnExport" text="Export to Excel" onAction="#onExportToExcel"
                        maxWidth="Infinity" styleClass="btn-export"/>
            </VBox>
        </VBox>
    </right>
</BorderPane>
